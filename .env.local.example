# Supabase — consigue estos valores en: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Solo para el servidor — NO expongas esto en el cliente
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# Web Push VAPID — genera con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Dominio público del sitio (sin slash final). Úsalo igual en Vercel.
NEXT_PUBLIC_APP_URL=https://www.olympodynami.com

# Resend (correos OTP). Verifica el dominio en Resend para enviar desde él.
RESEND_API_KEY=tu-resend-api-key
RESEND_FROM_EMAIL=Olympo <no-reply@olympodynami.com>

# Cron de purga de evidencia (Vercel Cron)
CRON_SECRET=cadena-aleatoria-larga

# Stripe (Fase 4) — claves SOLO en el entorno, nunca en el repo
STRIPE_SECRET_KEY=sk_live_o_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs (de Stripe Dashboard → cada producto/precio)
STRIPE_PRICE_PRO_MONTH=price_...
STRIPE_PRICE_PRO_YEAR=price_...
STRIPE_PRICE_ELITE_MONTH=price_...
STRIPE_PRICE_ELITE_YEAR=price_...
STRIPE_PRICE_PRO_SEAT_MONTH=price_...
STRIPE_PRICE_PRO_SEAT_YEAR=price_...
STRIPE_PRICE_ELITE_SEAT_MONTH=price_...
STRIPE_PRICE_ELITE_SEAT_YEAR=price_...
